# ==============================================================================
# Variables de entorno — udd-api-node
# ==============================================================================
# Copia este archivo a `.env` y completa los valores para tu entorno.
#   cp .env.example .env
#
# NUNCA subas tu archivo `.env` con valores reales al repositorio.
# Ver SECURITY.md y docs/conventions/secrets.md.
# ==============================================================================

# ── Entorno ───────────────────────────────────────────────────────────────
# Entorno de ejecución: development | production
NODE_ENV=development

# Puerto en el que escucha la aplicación
PORT=3000

# ── Notas ─────────────────────────────────────────────────────────────────
# Este proyecto usa datos SIMULADOS EN MEMORIA, por lo que NO requiere cadena
# de conexión a base de datos ni secretos de autenticación. Cuando se añadan
# esas capas (ver docs/product/roadmap.md), documenta aquí sus variables
# (p. ej. DATABASE_URL, AUTH_SECRET, AUTH_TOKEN_TTL).
